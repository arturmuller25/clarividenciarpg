# Configurações locais do Claude Code (não devem ir pro repositório)
.claude/settings.local.json

# IDE / editores
.vscode/
.idea/
*.swp
*.swo
*~

# Sistema operacional
Thumbs.db
Desktop.ini
.DS_Store

# Logs / cache PHP
*.log
error_log
php_errors.log
*.cache

# Dependências (caso futuro)
/vendor/
/node_modules/

# Backups e temporários
*.bak
*.tmp
*.orig

# Uploads de usuário (preserva estrutura via .gitkeep, ignora binários enviados)
uploads/*/*
!uploads/*/.gitkeep
!uploads/.htaccess
!uploads/README.md

# MP3 duplicados na raiz (canônicos vivem em assets/audio/)
/som_para_a_hero.mp3
/som_para_as_rolagens.mp3
/som_para_rolagem_multipla.mp3
/som_para_rolagem_com_muitos_dados.mp3

# Pasta temporária de assets do Claude Design (extraídos via handoff/ZIP).
